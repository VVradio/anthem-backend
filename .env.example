# ---- Copy this file to ".env" and fill in your real values ----
# NEVER commit your real .env file to git. Add ".env" to .gitignore.

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Auth — generate a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret

# AI provider keys (held only on the server, never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# Optional — only if you wire up other providers for multi-AI routing:
OPENAI_API_KEY=   # required for AI image generation (Iris/Mia); billed per image
# GOOGLE_API_KEY=

# Stripe (primary payment processor)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_INDIE=price_xxxx
STRIPE_PRICE_ARTIST=price_xxxx
STRIPE_PRICE_LABEL=price_xxxx
STRIPE_PRICE_INDIE_ANNUAL=price_xxxx
STRIPE_PRICE_ARTIST_ANNUAL=price_xxxx
STRIPE_PRICE_LABEL_ANNUAL=price_xxxx
# Promo coupons (create in Stripe → Coupons): 50% off first year, $7 first month
STRIPE_COUPON_LAUNCH=
STRIPE_COUPON_TRIAL=

# PayPal (optional secondary processor)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_ENV=sandbox

# Streaming analytics (optional — needed only for real Spotify/Apple data)
# Requires approved access; build against sample data until then.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=
# APPLE_MUSIC_DEV_TOKEN=

# Database (Supabase) — set both to enable persistent storage.
# Without these, the backend uses an in-memory store (data resets on restart).
# Find these in Supabase: Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
AYRSHARE_API_KEY=   # for direct social posting (get from ayrshare.com)
